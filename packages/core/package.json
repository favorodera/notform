{
  "name": "notform",
  "version": "2.0.0-alpha.3",
  "type": "module",
  "private": false,
  "description": "Vue Forms Without the Friction",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "homepage": "https://notform-docs.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/notform.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/notform/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:watch": "vitest watch --ui",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "tsdown": "^0.21.7",
    "type-fest": "^5.5.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "dequal": "^2.0.3",
    "dot-prop": "^10.1.0",
    "klona": "^2.0.6"
  },
  "keywords": [
    "notform",
    "vue",
    "form",
    "vue form",
    "validator",
    "vue form validator"
  ],
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@10.32.1"
}
