{
  "name": "notform-nuxt",
  "version": "2.0.0-alpha.5",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Official notform nuxt module - Vue Forms Without the Friction",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "homepage": "https://notform-docs.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/notform.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/notform/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "build": "nuxt-module-build build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "vitest",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "nuxt": "^4.4.2",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "notform-nuxt",
    "nuxt",
    "form",
    "nuxt form",
    "validator",
    "nuxt form validator"
  ]
}